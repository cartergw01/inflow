# Postgres connection (Neon in prod). Leave unset locally to use PGlite (.pglite/).
DATABASE_URL=

# Shared secret required by POST /api/ingest (sent as `x-ingest-secret` header).
INGEST_SECRET=

# Optional: enables the official X recent-search adapter. Off when unset.
# Keep a hard spending limit in the X Developer Console; the app also caps
# results per run. Usernames are comma-separated, without @.
X_BEARER_TOKEN=
X_CURATED_USERNAMES=Reuters,business,WSJ,CNBC,AP,nytimes,BBCWorld,NPR
X_MAX_POSTS_PER_RUN=25
